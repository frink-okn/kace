apiVersion: gateway.networking.k8s.io/v1beta1
kind: HTTPRoute
metadata:
  name: frink-{{ kg_name }}-qlever-route
spec:
  parentRefs:
  - name: ingress-gateway
    namespace: ingress
  hostnames:
  - "{{ host_name }}"
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: "/{{ kg_name }}"
    backendRefs:
    - name: frink-{{ kg_name }}-qlever-server
      port: 7001
    filters:
    - type: URLRewrite
      urlRewrite:
        path:
          type: ReplacePrefixMatch
          replacePrefixMatch: "/"
